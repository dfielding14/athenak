# AthenaK input for serial relativistic CR typed-v2 particle restart qualification

<comment>
problem   = serial relativistic CR typed-v2 particle restart witness

<job>
basename  = cr_relativistic_restart

<mesh>
nghost    = 2
nx1       = 8
x1min     = -1.0
x1max     = 1.0
ix1_bc    = periodic
ox1_bc    = periodic

nx2       = 8
x2min     = -1.0
x2max     = 1.0
ix2_bc    = periodic
ox2_bc    = periodic

nx3       = 8
x3min     = -1.0
x3max     = 1.0
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 8
nx2       = 8
nx3       = 8

<time>
evolution  = kinematic
integrator = rk2
cfl_number = 0.2
nlim       = 2
tlim       = 0.05
ndiag      = 1

<mhd>
eos         = ideal
reconstruct = plm
rsolver     = advect
gamma       = 1.666666667

<particles>
particle_type             = cosmic_ray
ppc                       = 0.001953125
nspecies                  = 1
pusher                    = relativistic_hc
interpolation             = trilinear
relativistic_field_source = prescribed_test
c_model                   = 1.0
alpha_s                   = 0.7
cfl_part                  = 0.05
min_mass                  = 1.0
subcycle                   = true
subcycle_strict            = true
subcycle_max_steps         = 32
subcycle_cell_fraction     = 0.5
subcycle_meshblock_fraction = 0.5
subcycle_gyro_fraction     = 0.25
subcycle_electric_kick_max = 0.1

<problem>
pgen_name                  = part_random
particle_position          = fixed
particle_x1                = 0.17
particle_x2                = -0.13
particle_x3                = 0.11
particle_velocity          = uniform
relativistic_initial_state = w
w0x                        = 0.21
w0y                        = -0.09
w0z                        = 0.04
cE0x                       = 0.03
cE0y                       = -0.02
cE0z                       = 0.01
B0x                        = 0.08
B0y                        = -0.05
B0z                        = 0.35
B_profile                  = uniform
prtcl_rst_flag              = 0
prtcl_res_file              = prst/rank_00000000/cr_relativistic_restart.00000.prst

<output1>
file_type   = prst
dt          = 0.02

<output2>
file_type   = rst
dt          = 0.02
