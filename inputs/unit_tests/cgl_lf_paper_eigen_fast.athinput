# Exact fast eigenmode check for the Squire et al. Figure 17 background.
# Eigenvectors are generated by scripts/generate_cgl_lf_eigenmode_inputs.py.
# The eigenvalue lambda uses Fourier convention d(delta U_k)/dt = lambda delta U_k.

<job>
basename = cgl_lf_paper_eigen_fast

<mesh>
nghost = 2
nx1 = 256
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 256
nx2 = 1
nx3 = 1

<time>
evolution = dynamic
integrator = rk2
sts_integrator = rkl2
sts_max_dt_ratio = -1.0
cfl_number = 0.15
nlim = -1
tlim = 2.00000000000000004e-03
ndiag = 1

<mhd>
eos = cgl
passive = false
cgl_heat_flux = landau_fluid
conductivity_integrator = sts
lf_k_parallel = 6.28318530717958623e+00
lf_coefficient_mode = background
lf_c_parallel0 = 2.23606797749978981e+00
cgl_lf_admissibility_check = true
reconstruct = plm
rsolver = hlle
gamma = 1.666666666666667
dfloor = 1.0e-12
pfloor = 1.0e-12
tfloor = 1.0e-12
sfloor = 1.0e-12
bfloor = 1.0e-10

<problem>
pgen_name = unit_tests/cgl_lf_quantitative_test
test_mode = paper_eigen_wave
eigen_branch = fast
mode_number = 1
rho0 = 1.00000000000000000e+00
ppar0 = 5.00000000000000000e+00
pperp0 = 5.00000000000000000e+00
b0 = 1.00000000000000000e+00
by0 = 1.41421356237309515e+00
bz0 = 5.00000000000000000e-01
amp = 1.00000000000000008e-05
eigen_lambda_re = -5.75496509674108481e-01
eigen_lambda_im = -2.07549593325158028e+01
eigen_wave_rel_tol = 7.49999999999999972e-02
eigen_component_floor = 1.0e-4
eigen_zero_abs_tol = 1.0e-8
eigen_rho_re = 5.45338153224602662e-01
eigen_rho_im = 1.51212150669559533e-02
eigen_vx_re = 1.80277563773199523e+00
eigen_vx_im = -3.97863078099230634e-19
eigen_vy_re = -4.35793364223282464e-01
eigen_vy_im = -2.84325977788146035e-02
eigen_vz_re = -1.54076221519190593e-01
eigen_vz_im = -1.00524413480747293e-02
eigen_by_re = 9.02813262694281526e-01
eigen_by_im = 3.36407868110345301e-02
eigen_bz_re = 3.19192690098139442e-01
eigen_bz_im = 1.18938142392667791e-02
eigen_ppar_re = 3.66059491601817388e+00
eigen_ppar_im = -2.51042359346720201e-01
eigen_pperp_re = 4.90002139378243839e+00
eigen_pperp_im = -2.04244727770575590e-01
validation_output = false
validation_output_dir = docs/figures/data
