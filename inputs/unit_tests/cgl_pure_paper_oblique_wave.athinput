# Paper-style 1D oblique pure-CGL linear initial-value check without LF heat flux.
# Uses the same Figure 17 background as cgl_lf_paper_oblique_wave.athinput.
# This seeds transverse velocity only; it is not an exact CGL eigenmode.

<job>
basename = cgl_pure_paper_oblique_wave

<mesh>
nghost = 2
nx1 = 128
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 128
nx2 = 1
nx3 = 1

<time>
evolution = dynamic
integrator = rk2
cfl_number = 0.15
nlim = -1
tlim = 0.002
ndiag = 1

<mhd>
eos = cgl
passive = false
reconstruct = plm
rsolver = hlle
gamma = 1.666666666666667
dfloor = 1.0e-12
pfloor = 1.0e-12
tfloor = 1.0e-12
sfloor = 1.0e-12
bfloor = 1.0e-10

<problem>
pgen_name = cgl_landau_fluid
test_mode = paper_oblique_wave
mode_number = 1
rho0 = 1.0
ppar0 = 5.0
pperp0 = 5.0
b0 = 1.0
by0 = 1.4142135623730951
bz0 = 0.5
amp = 1.0e-5
reference_steps = 20000
wave_rel_tol = 4.0e-1
validation_output = false
validation_output_dir = docs/figures/data
