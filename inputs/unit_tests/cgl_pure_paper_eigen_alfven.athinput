# Exact alfven eigenmode check for the Squire et al. Figure 17 background.
# Eigenvectors are generated by scripts/generate_cgl_lf_eigenmode_inputs.py.
# The eigenvalue lambda uses Fourier convention d(delta U_k)/dt = lambda delta U_k.

<job>
basename = cgl_pure_paper_eigen_alfven

<mesh>
nghost = 2
nx1 = 256
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 256
nx2 = 1
nx3 = 1

<time>
evolution = dynamic
integrator = rk2
cfl_number = 0.15
nlim = -1
tlim = 2.00000000000000004e-03
ndiag = 1

<mhd>
eos = cgl
passive = false
reconstruct = plm
rsolver = hlle
gamma = 1.666666666666667
dfloor = 1.0e-12
pfloor = 1.0e-12
tfloor = 1.0e-12
sfloor = 1.0e-12
bfloor = 1.0e-10

<problem>
pgen_name = cgl_landau_fluid
test_mode = paper_eigen_wave
eigen_branch = alfven
mode_number = 1
rho0 = 1.00000000000000000e+00
ppar0 = 5.00000000000000000e+00
pperp0 = 5.00000000000000000e+00
b0 = 1.00000000000000000e+00
by0 = 1.41421356237309515e+00
bz0 = 5.00000000000000000e-01
amp = 1.00000000000000008e-05
eigen_lambda_re = 1.88737914186276612e-15
eigen_lambda_im = -6.28318530717958268e+00
eigen_wave_rel_tol = 7.49999999999999972e-02
eigen_component_floor = 1.0e-4
eigen_zero_abs_tol = 1.0e-8
eigen_rho_re = -3.16019848926539942e-17
eigen_rho_im = 2.17408187934021844e-17
eigen_vx_re = -1.06561396387855250e-16
eigen_vx_im = -6.07698514494189231e-17
eigen_vy_re = 6.37377439199097395e-01
eigen_vy_im = 7.78686416928631983e-16
eigen_vz_re = -1.80277563773199323e+00
eigen_vz_im = -1.68750638011347778e-15
eigen_by_re = -6.37377439199098172e-01
eigen_by_im = 8.95985577629126150e-17
eigen_bz_re = 1.80277563773199478e+00
eigen_bz_im = 0.00000000000000000e+00
eigen_ppar_re = -6.26745731137286329e-16
eigen_ppar_im = 1.14423378128321653e-15
eigen_pperp_re = -3.30935211925391309e-17
eigen_pperp_im = 2.27669322014597155e-17
validation_output = false
validation_output_dir = docs/figures/data
