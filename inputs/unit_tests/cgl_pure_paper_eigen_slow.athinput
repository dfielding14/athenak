# Exact slow eigenmode check for the Squire et al. Figure 17 background.
# Eigenvectors are generated by scripts/generate_cgl_lf_eigenmode_inputs.py.
# The eigenvalue lambda uses Fourier convention d(delta U_k)/dt = lambda delta U_k.

<job>
basename = cgl_pure_paper_eigen_slow

<mesh>
nghost = 2
nx1 = 256
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 256
nx2 = 1
nx3 = 1

<time>
evolution = dynamic
integrator = rk2
cfl_number = 0.15
nlim = -1
tlim = 2.00000000000000004e-03
ndiag = 1

<mhd>
eos = cgl
passive = false
reconstruct = plm
rsolver = hlle
gamma = 1.666666666666667
dfloor = 1.0e-12
pfloor = 1.0e-12
tfloor = 1.0e-12
sfloor = 1.0e-12
bfloor = 1.0e-10

<problem>
pgen_name = unit_tests/cgl_lf_quantitative_test
test_mode = paper_eigen_wave
eigen_branch = slow
mode_number = 1
rho0 = 1.00000000000000000e+00
ppar0 = 5.00000000000000000e+00
pperp0 = 5.00000000000000000e+00
b0 = 1.00000000000000000e+00
by0 = 1.41421356237309515e+00
bz0 = 5.00000000000000000e-01
amp = 1.00000000000000008e-05
eigen_lambda_re = -1.73794154552772242e-15
eigen_lambda_im = -1.22193144415755484e+01
eigen_wave_rel_tol = 7.49999999999999972e-02
eigen_component_floor = 1.0e-4
eigen_zero_abs_tol = 1.0e-8
eigen_rho_re = 1.86452913141115728e-01
eigen_rho_im = -1.16945657606808044e-16
eigen_vx_re = 3.62606968095577020e-01
eigen_vx_im = -1.39432246336293538e-16
eigen_vy_re = 1.38806549994934536e+00
eigen_vy_im = 6.94219150280078776e-16
eigen_vz_re = 4.90755263872637071e-01
eigen_vz_im = 1.74976908090328626e-16
eigen_by_re = -4.50060611612935701e-01
eigen_by_im = -5.56714499983518927e-16
eigen_bz_re = -1.59120455208235728e-01
eigen_bz_im = -5.56992318962793756e-17
eigen_ppar_re = 5.00000000000000000e+00
eigen_ppar_im = 0.00000000000000000e+00
eigen_pperp_re = -1.69338585736056257e-01
eigen_pperp_im = -1.12169754401136945e-15
validation_output = false
validation_output_dir = docs/figures/data
