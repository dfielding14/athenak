# LEGACY NAME: engineering scaffold only; not Sun & Bai (2023) reproduction evidence.
# AthenaXXX input file: PIC parallel shock benchmark (Section 5.4 style, HPC)

<comment>
problem   = pic_parallel_shock Section 5.4 scale (cluster-GPU profile)

<job>
basename  = pic_parallel_shock_s54_hpc

<mesh>
nghost    = 2
# Section 5.4 style domain in c/omega_pi units:
# Lx = 4.8e4, Ly = 3.12e3
nx1       = 4000
x1min     = 0.0
x1max     = 48000.0
ix1_bc    = reflect
ox1_bc    = inflow

nx2       = 260
x2min     = 0.0
x2max     = 3120.0
ix2_bc    = periodic
ox2_bc    = periodic

nx3       = 1
x3min     = 0.0
x3max     = 1.0
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
# Figure 8 caption in the paper uses 20 x 20 cells per MeshBlock.
nx1       = 20
nx2       = 20
nx3       = 1

<mesh_refinement>
refinement           = adaptive
# 3 total levels (root + 2 refined), matching Section 5.4.
num_levels           = 3
# Built-in gradient criteria disabled; pgen curvature callback drives AMR.
ddens_max            = 0.0
dpres_max            = 0.0
dvel_max             = 0.0
ncycle_check         = 1
refinement_interval  = 1
max_nmb_per_rank     = 8192

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.3
# Paper diagnostics emphasize t = 500 and t = 1200 (Omega0^-1).
tlim       = 1200.0
nlim       = 200000
ndiag      = 50

<mhd>
eos         = ideal
reconstruct = plm
rsolver     = llf
gamma       = 1.666666667

<particles>
particle_type                     = cosmic_ray
ppc                               = 0.0
pusher                            = boris_tsc
nspecies                          = 1
cr_distribution                   = random
deposit_moments                   = true
deposit_order                     = 1
# Section 5.4 target is ~40 ppc (finest) and ~640 ppc (coarsest) downstream.
# This qscale is the first-pass macro-mass calibration knob for that regime.
deposit_qscale                    = 9.0e-4
couple_moments_to_mhd             = true
couple_j_to_efield_representation = cell_centered
couple_moments_momentum_to_mhd    = false
couple_moments_energy_to_mhd      = false
cr_vx0                            = 0.0
cr_vy0                            = 0.0
cr_vz0                            = 0.0
pic_background_mode               = coupled
pic_feedback_mode                 = coupled
pic_enable_2d3v                   = true
pic_sort_interval                 = 16
pic_intermediate_arrays           = auto
# The reduced-speed-of-light parameter used in Section 5.4 is not implemented
# in this nonrelativistic Boris branch. Non-default pic_cr_light_speed values
# are intentionally rejected rather than silently ignored.

<species0>
mass   = 1.0
charge = 1.0

<problem>
pgen_name                     = pic_parallel_shock
ps_rho0                       = 1.0
ps_p0                         = 0.10
ps_u0                         = 30.0
ps_b0                         = 1.0
ps_eta                        = 1.0e-3
ps_vinj_over_u0               = 3.16227766017
ps_inject_half_width_cells    = 0.5
# Section 5.4 removes particles injected before t=45; emulate by starting at 45.
ps_inject_t_start             = 45.0
ps_inject_t_stop              = 1.0e9
ps_enable_injection           = true
ps_enable_gas_subtraction     = true
ps_enable_curvature_amr       = true
ps_refine_curv                = 1.0
ps_derefine_curv              = 0.1
ps_rho_floor_frac             = 1.0e-6
ps_p_floor_frac               = 1.0e-8
ps_inject_species             = 0
ps_inject_seed                = 1234
ps_seed_noise_amp             = 0.0
ps_seed_noise_seed            = 1234
# Large domain run does not require moving-frame/recentering.
ps_enable_frame_tracking      = false
ps_frame_mode                 = velocity
ps_frame_t_start              = 0.0
ps_frame_t_ramp               = 0.0
ps_frame_vfrac                = 1.0
ps_frame_dv_max               = 1.0e99
ps_frame_apply_to_particles   = true
ps_frame_apply_to_inflow      = true
ps_frame_require_uniform      = true
ps_frame_diag_dcycle          = 2000
ps_feedback_diag_dcycle       = 2000
ps_recenter_x_target          = 24000.0
ps_recenter_x_trigger         = 36000.0
ps_recenter_shift_cells       = 2
ps_recenter_vshock_model      = -1.0

<output1>
file_type   = bin
variable    = mhd_w_d
id          = rho
dcycle      = 1000
ghost_zones = false

<output2>
file_type   = bin
variable    = mhd_bmag
id          = bmag
dcycle      = 1000
ghost_zones = false

<output3>
file_type   = pvtk
variable    = prtcl_all
id          = prtcl_all
dcycle      = 2000

<output4>
file_type   = rst
dcycle      = 5000
