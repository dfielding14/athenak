# AthenaXXX input file for EM-vacuum-style linear-wave convergence with particles active

<comment>
problem   = PIC-staged EM-vacuum linear-wave convergence anchor

<job>
basename  = pic_em_vacuum_wave

<mesh>
nghost    = 3
nx1       = 32
x1min     = 0.0
x1max     = 3.0
ix1_bc    = periodic
ox1_bc    = periodic

nx2       = 16
x2min     = 0.0
x2max     = 1.5
ix2_bc    = periodic
ox2_bc    = periodic

nx3       = 16
x3min     = 0.0
x3max     = 1.5
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 8
nx2       = 8
nx3       = 8

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.3
nlim       = 1000
tlim       = 1.0
ndiag      = 1

<mhd>
eos         = ideal
reconstruct = plm
rsolver     = hlle
gamma       = 1.66666666667

<particles>
particle_type         = cosmic_ray
ppc                   = 1.0
pusher                = drift
nspecies              = 1
cr_distribution       = center
deposit_moments       = false
deposit_order         = 1
deposit_qscale        = 1.0
couple_moments_to_mhd = false
cr_vx0                = 0.0
cr_vy0                = 0.0
cr_vz0                = 0.0
pic_background_mode   = coupled
pic_feedback_mode     = test_particle

<species0>
mass   = 1.0
charge = 0.0

<problem>
pgen_name = linear_wave
wave_flag = 1
amp       = 1.0e-6
vflow     = 0.0
along_x1  = true
along_x2  = false
along_x3  = false

<output1>
file_type   = tab
variable    = mhd_w
data_format = %12.5e
dt          = -1.0
slice_x2    = 0.75
slice_x3    = 0.75
ghost_zones = false

<output2>
file_type   = tab
variable    = mhd_bcc
data_format = %12.5e
dt          = -1.0
slice_x2    = 0.75
slice_x3    = 0.75
ghost_zones = false

<output3>
file_type   = vtk
variable    = mhd_w
dt          = -1.0
ghost_zones = false

<output4>
file_type   = vtk
variable    = mhd_bcc
dt          = -1.0
ghost_zones = false

<output5>
file_type   = hst
data_format = %12.5e
dt          = -1.0
