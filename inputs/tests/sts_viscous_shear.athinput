# Shear mode with bounded power-law temperature-dependent viscosity.

<job>
basename = sts_viscous_shear

<mesh>
nghost = 2
nx1 = 256
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 128
nx2 = 1
nx3 = 1

<time>
evolution = dynamic
integrator = rk2
cfl_number = 0.4
tlim = 0.05
nlim = -1
ndiag = 100000
sts_integrator = rkl2
sts_max_dt_ratio = -1.0

<hydro>
eos = ideal
gamma = 1.6666666666667
reconstruct = plm
rsolver = hllc
viscosity = 0.02
tdep_viscosity = true
viscosity_tref = 1.0
viscosity_exponent = 1.5
viscosity_floor = 0.002
viscosity_ceiling = 0.04
viscosity_integrator = sts

<problem>
pgen_name = sts_diffusion
sts_case = viscous_shear
pressure = 1.0
tcold = 0.5
thot = 2.0
amp = 0.1

<output1>
file_type = tab
variable = hydro_w
data_format = %24.16e
dt = 0.05
slice_x2 = 0.0
slice_x3 = 0.0
