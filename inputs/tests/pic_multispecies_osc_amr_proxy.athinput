# AthenaXXX input file for multi-species backreaction oscillation (AMR-style proxy)

<comment>
problem   = Multi-species coupled oscillation with nested static refinement

<job>
basename  = pic_multispecies_osc_amr_proxy

<mesh>
nghost    = 2
nx1       = 16
x1min     = 0.0
x1max     = 16.0
ix1_bc    = periodic
ox1_bc    = periodic

nx2       = 8
x2min     = 0.0
x2max     = 8.0
ix2_bc    = periodic
ox2_bc    = periodic

nx3       = 8
x3min     = 0.0
x3max     = 8.0
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 4
nx2       = 4
nx3       = 4

<mesh_refinement>
refinement = static

<refinement1>
level = 1
x1min = 2.0
x1max = 14.0
x2min = 1.0
x2max = 7.0
x3min = 1.0
x3max = 7.0

<refinement2>
level = 2
x1min = 6.0
x1max = 10.0
x2min = 3.0
x2max = 5.0
x3min = 3.0
x3max = 5.0

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.2
nlim       = 80
tlim       = 20.0
ndiag      = 1

<mhd>
eos         = ideal
reconstruct = plm
rsolver     = llf
gamma       = 1.66666666667

<particles>
particle_type            = cosmic_ray
ppc                      = 1.0
pusher                   = boris_tsc
nspecies                 = 2
cr_distribution          = center
deposit_moments          = true
deposit_order            = 1
deposit_qscale           = 1.0
couple_moments_to_mhd    = true
couple_j_to_efield_coeff = 1.0
couple_j_to_efield_representation = cell_centered
couple_j_deposition_mode = cc_convert
couple_moments_momentum_to_mhd = true
couple_moments_energy_to_mhd   = true
couple_fluid_feedback_order    = mhd_src_terms
couple_moments_momentum_coeff  = 1.0
couple_moments_energy_coeff    = 1.0
cr_vx0                   = 0.0
cr_vy0                   = 0.0
cr_vz0                   = 0.0
pic_background_mode      = coupled
pic_feedback_mode        = coupled

<species0>
mass   = 1.0
charge = -1.0
vx0    = 0.0
vy0    = 0.2
vz0    = 0.0

<species1>
mass   = 1.0
charge = 1.0
vx0    = 0.0
vy0    = -0.2
vz0    = 0.0

<problem>
pgen_name = linear_wave
wave_flag = 0
amp       = 0.0
vflow     = 0.0
along_x1  = true
along_x2  = false
along_x3  = false

<output1>
file_type   = bin
variable    = mhd_u_m2
id          = mhd_u_m2
dcycle      = 1
ghost_zones = false

<output2>
file_type   = bin
variable    = mhd_u_e
id          = mhd_u_e
dcycle      = 1
ghost_zones = false
