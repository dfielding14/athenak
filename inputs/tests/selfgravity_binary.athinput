# AthenaK input file for isolated binary self-gravity tests

<comment>
problem   = SelfGravity isolated binary multipole regression

<job>
basename  = SelfGravityBinary

<mesh>
nghost    = 3
nx1       = 32
x1min     = -0.5
x1max     = 0.5
ix1_bc    = outflow
ox1_bc    = outflow

nx2       = 32
x2min     = -0.5
x2max     = 0.5
ix2_bc    = outflow
ox2_bc    = outflow

nx3       = 32
x3min     = -0.5
x3max     = 0.5
ix3_bc    = outflow
ox3_bc    = outflow

<meshblock>
nx1       = 16
nx2       = 16
nx3       = 16

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.2
nlim       = 1
tlim       = 1.0
ndiag      = 1

<hydro>
eos         = isothermal
reconstruct = plm
rsolver     = llf
iso_sound_speed = 1.0

<gravity>
four_pi_G = 1.0
threshold = 1e-6
niteration = 1
npresmooth = 1
npostsmooth = 1
full_multigrid = true
fmg_ncycle = 1
mg_nghost = 1
root_on_host = false
mg_bc = multipole
mporder = 4
auto_mporigin = true
nodipole = false
show_defect = false
profile = false

<problem>
pgen_name = binary_gravity
four_pi_G = 1.0
x1        = 0.15
y1        = 0.0
z1        = 0.0
x2        = -0.15
y2        = 0.0
z2        = 0.0
radius    = 0.10
m1        = 1.0
m2        = 0.5

<output1>
file_type = bin
variable  = grav_phi
dt        = 1.0
