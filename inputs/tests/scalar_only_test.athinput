# Test input for scalar_only feature
# Uniform velocity field with passive scalar advection

<comment>
problem   = scalar_only test
reference = autonomous scalar implementation

<job>
problem_id = scalar_only_test
basename   = scalar_only

<time>
evolution  = dynamic
cfl_number = 0.4
tlim       = 0.1
nlim       = 10

<mesh>
nghost = 2
nx1    = 32
x1min  = 0.0
x1max  = 1.0
ix1_bc = periodic
ox1_bc = periodic

nx2    = 32
x2min  = 0.0
x2max  = 1.0
ix2_bc = periodic
ox2_bc = periodic

nx3    = 1
x3min  = 0.0
x3max  = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 32
nx2 = 32
nx3 = 1

<hydro>
eos             = ideal
gamma           = 1.6666666666667
reconstruct     = plm
rsolver         = hllc
nscalars        = 1
scalar_only     = true

<problem>
rho0  = 1.0
temp0 = 1.0
vx0   = 1.0
vy0   = 0.5
vz0   = 0.0

<output1>
file_type  = vtk
variable   = hydro_w
dt         = 0.05
