# Scalar-mixing visualization sweep: 3D Clebsch velocity power spectra

<comment>
problem   = scalar mixing Clebsch alpha sweep in 3D
reference = 128^3 Clebsch velocity-spectrum visualization sweep

<job>
problem_id = scalar_mixing
basename   = scalar_mix_clebsch_alpha_sweep

<time>
evolution  = dynamic
cfl_number = 0.4
tlim       = 1.0e-6
nlim       = -1

<mesh>
nghost = 2
nx1    = 128
x1min  = 0.0
x1max  = 1.0
ix1_bc = periodic
ox1_bc = periodic

nx2    = 128
x2min  = 0.0
x2max  = 1.0
ix2_bc = periodic
ox2_bc = periodic

nx3    = 128
x3min  = 0.0
x3max  = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 64
nx2 = 64
nx3 = 64

<hydro>
eos             = ideal
gamma           = 1.6666666666667
reconstruct     = plm
rsolver         = hllc
nscalars        = 1
scalar_only     = true

<problem>
rho0                          = 1.0
temp0                         = 1.0
scalar_init                   = 0.5
user_srcs                     = false
mean_gradient                 = 0.0
turb_velocity_method          = clebsch
turb_alpha                    = 0.3333333333333333
turb_v_rms                    = 1.0
turb_nlow                     = 2
turb_nhigh                    = 32
turb_expo                     = 1.6666667
turb_sol_frac                 = 1.0
turb_rseed                    = 24680
turb_k_crit                   = 2.0
turb_dump_generator_diagnostics = true

<output1>
file_type  = bin
variable   = hydro_w
dt         = 1.0e-6
