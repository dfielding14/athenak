# AthenaXXX input file for Entity-style PIC deposit test (reflect boundaries)

<comment>
problem   = Entity-style pair-plasma PIC deposit reflect-boundary test

<job>
basename  = pic_entity_dep_reflect

<mesh>
nghost    = 2
nx1       = 16
x1min     = 0.0
x1max     = 1.0
ix1_bc    = reflect
ox1_bc    = reflect

nx2       = 16
x2min     = 0.0
x2max     = 1.0
ix2_bc    = reflect
ox2_bc    = reflect

nx3       = 4
x3min     = 0.0
x3max     = 1.0
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 4
nx2       = 4
nx3       = 4

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.3
nlim       = 12
tlim       = 1.0
ndiag      = 1

<mhd>
eos         = ideal
reconstruct = plm
rsolver     = llf
gamma       = 1.66666666667

<particles>
particle_type         = cosmic_ray
ppc                   = 1.0
pusher                = drift
nspecies              = 2
cr_distribution       = center
deposit_moments       = true
deposit_order         = 1
deposit_qscale        = 1.0
couple_moments_to_mhd = false
cr_vx0                = 1.5
cr_vy0                = -1.2
cr_vz0                = 0.4

<species0>
mass   = 1.0
charge = -1.0

<species1>
mass   = 1.0
charge = 1.0

<problem>
pgen_name = linear_wave
wave_flag = 0
amp       = 1.0e-6
vflow     = 0.0
along_x1  = true
along_x2  = false
along_x3  = false

<output1>
file_type   = bin
variable    = prtcl_rho
id          = prtcl_rho
dcycle      = 1
ghost_zones = false

<output2>
file_type   = bin
variable    = prtcl_jx
id          = prtcl_jx
dcycle      = 1
ghost_zones = false

<output3>
file_type   = bin
variable    = prtcl_jy
id          = prtcl_jy
dcycle      = 1
ghost_zones = false

<output4>
file_type   = bin
variable    = prtcl_jz
id          = prtcl_jz
dcycle      = 1
ghost_zones = false

<output5>
file_type   = bin
variable    = prtcl_d
id          = prtcl_d
dcycle      = 1
ghost_zones = false
