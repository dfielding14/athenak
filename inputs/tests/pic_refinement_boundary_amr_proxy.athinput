# AthenaXXX input file for PIC refinement-boundary AMR-style proxy

<comment>
problem   = AMR-style refinement-boundary homogeneity/conservation proxy

<job>
basename  = pic_refinement_boundary_amr_proxy

<mesh>
nghost    = 2
nx1       = 16
x1min     = 0.0
x1max     = 16.0
ix1_bc    = periodic
ox1_bc    = periodic

nx2       = 8
x2min     = 0.0
x2max     = 8.0
ix2_bc    = periodic
ox2_bc    = periodic

nx3       = 8
x3min     = 0.0
x3max     = 8.0
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 4
nx2       = 4
nx3       = 4

<mesh_refinement>
refinement = static

<refinement1>
level = 1
x1min = 2.0
x1max = 14.0
x2min = 1.0
x2max = 7.0
x3min = 1.0
x3max = 7.0

<refinement2>
level = 2
x1min = 6.0
x1max = 10.0
x2min = 3.0
x2max = 5.0
x3min = 3.0
x3max = 5.0

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.05
nlim       = 40
tlim       = 4.0
ndiag      = 1

<particles>
particle_type           = cosmic_ray
ppc                     = 16.0
pusher                  = boris_tsc
nspecies                = 1
cr_distribution         = random
deposit_moments         = true
deposit_order           = 1
deposit_qscale          = 1.0
couple_moments_to_mhd   = false
cr_vx0                  = 0.3
cr_vy0                  = 0.0
cr_vz0                  = 0.0
pic_background_mode     = no_mhd
pic_feedback_mode       = test_particle
pic_no_mhd_bx           = 0.0
pic_no_mhd_by           = 0.0
pic_no_mhd_bz           = 0.0
pic_deltaf_mode         = on
pic_deltaf_f0           = uniform_quiet

<species0>
mass   = 1.0
charge = 1.0

<problem>
pgen_name = linear_wave
wave_flag = 0
amp       = 0.0
vflow     = 0.0
along_x1  = true
along_x2  = false
along_x3  = false

<output1>
file_type   = bin
variable    = prtcl_rho
id          = prtcl_rho
dcycle      = 2
ghost_zones = false
