# Static pressure-balanced front with bounded power-law thermal conductivity.

<job>
basename = sts_thermal_front

<mesh>
nghost = 2
nx1 = 256
x1min = 0.0
x1max = 1.0
ix1_bc = outflow
ox1_bc = outflow
nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 128
nx2 = 1
nx3 = 1

<time>
evolution = dynamic
integrator = rk2
cfl_number = 0.4
tlim = 0.04
nlim = -1
ndiag = 100000
sts_integrator = rkl2
sts_max_dt_ratio = -1.0

<hydro>
eos = ideal
gamma = 1.6666666666667
reconstruct = plm
rsolver = hllc
conductivity = 0.01
conductivity_model = power_law
conductivity_tref = 1.0
conductivity_exponent = 2.5
conductivity_floor = 0.0001
conductivity_ceiling = 0.04
conductivity_integrator = sts

<problem>
pgen_name = sts_diffusion
sts_case = thermal_front
pressure = 1.0
tcold = 0.25
thot = 2.0
xcenter = 0.5
front_width = 0.03

<output1>
file_type = tab
variable = hydro_w
data_format = %24.16e
dt = 0.04
slice_x2 = 0.0
slice_x3 = 0.0
