# MHD passive-scalar advection with independent RKL2 STS diffusivities.

<job>
basename = sts_mhd_scalar_advection

<mesh>
nghost = 2
nx1 = 128
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 64
nx2 = 1
nx3 = 1

<time>
evolution = kinematic
integrator = rk2
cfl_number = 0.4
tlim = 0.05
nlim = -1
ndiag = 100000
sts_integrator = rkl2
sts_max_dt_ratio = 1.0

<mhd>
eos = isothermal
iso_sound_speed = 1.0
reconstruct = plm
rsolver = advect
nscalars = 2
scalar_diffusivity = 0.005
scalar_diffusivity_0 = 0.005
scalar_diffusivity_1 = 0.05
scalar_diffusivity_integrator = sts

<problem>
pgen_name = advection
advect_dens = false
flow_dir = 1
iproblem = 1
velocity = 0.25
amplitude = 0.2

<output1>
file_type = tab
variable = mhd_w
data_format = %24.16e
dt = 0.05
slice_x2 = 0.0
slice_x3 = 0.0
