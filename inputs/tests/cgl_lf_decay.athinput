# Routine CPU regression for CGL Landau-fluid parallel temperature decay.

<job>
basename = cgl_lf_decay

<mesh>
nghost = 2
nx1 = 64
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 64
nx2 = 1
nx3 = 1

<time>
evolution = dynamic
integrator = rk2
sts_integrator = rkl2
sts_max_dt_ratio = -1.0
cfl_number = 0.4
nlim = 2
tlim = 0.005
ndiag = 1

<mhd>
eos = cgl
passive = false
cgl_heat_flux = landau_fluid
cgl_heat_flux_integrator = sts
cgl_lf_strict_admissibility = true
lf_k_parallel = 32.0
lf_coefficient_mode = local
nu_coll = 0.0
reconstruct = plm
rsolver = hlle
gamma = 1.666666666666667
dfloor = 1.0e-12
pfloor = 1.0e-12
tfloor = 1.0e-12
sfloor = 1.0e-12
bfloor = 1.0e-10

<problem>
pgen_name = cgl_landau_fluid
test_mode = parallel_decay
rho0 = 1.0
ppar0 = 1.0
pperp0 = 1.0
b0 = 1.0
amp = 0.01

<output1>
file_type = hst
data_format = %24.16e
dcycle = 1

<output2>
file_type = tab
variable = mhd_w
data_format = %24.16e
dt = 0.005
slice_x2 = 0.0
slice_x3 = 0.0
