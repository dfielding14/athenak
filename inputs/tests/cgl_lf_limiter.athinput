# Routine CPU regression for LF limiter occupancy and strict stage admissibility.

<job>
basename = cgl_lf_limiter

<mesh>
nghost = 2
nx1 = 64
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 64
nx2 = 1
nx3 = 1

<time>
evolution = kinematic
integrator = rk2
sts_integrator = rkl2
sts_max_dt_ratio = 1000.0
cfl_number = 0.4
nlim = 1
tlim = 0.005
ndiag = 1

<mhd>
eos = cgl
passive = false
mirror_limiter = true
backup_limiters = true
limiter_nu_coll = 100.0
cgl_heat_flux = landau_fluid
cgl_heat_flux_integrator = sts
cgl_lf_strict_admissibility = true
lf_k_parallel = 6.283185307179586
lf_coefficient_mode = background
lf_c_parallel0 = 1.0
reconstruct = plm
rsolver = advect
gamma = 1.666666666666667
dfloor = 1.0e-12
pfloor = 1.0e-12
tfloor = 1.0e-12
sfloor = 1.0e-12
bfloor = 1.0e-10

<problem>
pgen_name = cgl_landau_fluid
test_mode = limiter_stress
limiter_kind = mirror
rho0 = 1.0
ppar0 = 1.0
pperp0 = 1.75
b0 = 1.0
amp = 0.1
backup_bound_tol = 1.02

<output1>
file_type = hst
data_format = %24.16e
dcycle = 1
