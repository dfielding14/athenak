# Scalar-mixing regression: projection velocity in true 2D

<comment>
problem   = scalar mixing projection regression in 2D
reference = scalar_mixing projection 2D spectrum regression

<job>
problem_id = scalar_mixing
basename   = scalar_mix_proj_2d

<time>
evolution  = dynamic
cfl_number = 0.4
tlim       = 0.05
nlim       = -1

<mesh>
nghost = 2
nx1    = 48
x1min  = 0.0
x1max  = 1.0
ix1_bc = periodic
ox1_bc = periodic

nx2    = 48
x2min  = 0.0
x2max  = 1.0
ix2_bc = periodic
ox2_bc = periodic

nx3    = 1
x3min  = 0.0
x3max  = 1.0
ix3_bc = reflect
ox3_bc = reflect

<meshblock>
nx1 = 48
nx2 = 48
nx3 = 1

<hydro>
eos             = ideal
gamma           = 1.6666666666667
reconstruct     = plm
rsolver         = hllc
nscalars        = 1
scalar_only     = true

<problem>
rho0           = 1.0
temp0          = 1.0
user_srcs      = false
mean_gradient  = 0.0
turb_v_rms     = 1.0
turb_nlow      = 2
turb_nhigh     = 6
turb_expo      = 1.6666667
turb_rseed     = 12345
turb_k_crit    = 16.0
turb_dump_generator_diagnostics = true

<output1>
file_type  = bin
variable   = hydro_w
dt         = 0.05
