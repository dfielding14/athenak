# Scalar mixing test in true 2D: reflected collapsed x3 disables v3

<comment>
problem   = scalar mixing with mean gradient forcing in true 2D
 reference = scalar_mixing true 2D verification

<job>
problem_id = scalar_mixing
basename   = scalar_mix_2d

<time>
evolution  = dynamic
cfl_number = 0.4
tlim       = 0.2
nlim       = -1

<mesh>
nghost = 2
nx1    = 64
x1min  = 0.0
x1max  = 1.0
ix1_bc = periodic
ox1_bc = periodic

nx2    = 64
x2min  = 0.0
x2max  = 1.0
ix2_bc = periodic
ox2_bc = periodic

nx3    = 1
x3min  = 0.0
x3max  = 1.0
ix3_bc = reflect
ox3_bc = reflect

<meshblock>
nx1 = 64
nx2 = 64
nx3 = 1

<hydro>
eos             = ideal
gamma           = 1.6666666666667
reconstruct     = plm
rsolver         = hllc
nscalars        = 1
scalar_only     = true

<problem>
rho0           = 1.0
temp0          = 1.0
scalar_init    = 10.0
user_srcs      = true
mean_gradient  = 1.0
turb_v_rms     = 1.0
turb_nlow      = 1
turb_nhigh     = 16
turb_expo      = 1.6666667
turb_sol_frac  = 1.0
turb_rseed     = 12345

<output1>
file_type  = bin
variable   = hydro_w
dt         = 0.2
