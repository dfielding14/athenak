# CGL Landau-fluid plus modal turbulence-driving AMR/restart integration regression.

<job>
basename = cgl_lf_turb_driving_amr

<mesh>
nghost = 2
nx1 = 24
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 24
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 8
nx2 = 8
nx3 = 1

<mesh_refinement>
refinement = adaptive
num_levels = 2
ncycle_check = 1
refinement_interval = 1
prolong_primitives = false
max_nmb_per_rank = 256

<amr_criterion1>
method = user

<time>
evolution = dynamic
integrator = rk2
sts_integrator = rkl2
sts_max_dt_ratio = 1.0
cfl_number = 0.1
nlim = 3
tlim = 0.02
ndiag = 1

<mhd>
eos = cgl
passive = false
cgl_heat_flux = landau_fluid
cgl_heat_flux_integrator = sts
cgl_lf_strict_admissibility = true
lf_k_parallel = 32.0
lf_coefficient_mode = local
reconstruct = plm
rsolver = hlle
gamma = 1.666666666666667
dfloor = 1.0e-12
pfloor = 1.0e-12
tfloor = 1.0e-12
sfloor = 1.0e-12
bfloor = 1.0e-10

<problem>
pgen_name = divb_amr
user_hist = true
refine_levels = 1
rho0 = 1.0
ppar0 = 10.0
pperp0 = 10.01
vx0 = 0.08
vy0 = 0.05
vz0 = 0.0
guide_b1 = 0.7
guide_b2 = 0.2
guide_b3 = -0.15
field_amp = 0.05
field_k = 2.0

<turb_driving>
turb_flag = 2
tcorr = 0.25
dt_update = 0.01
normalization = accel_rms
accel_rms = 0.02
nlow = 1
nhigh = 3
npeak = 2
spectrum = parabolic
driving_type = 1
sol_fraction = 1.0
rseed = 314159

<output1>
file_type = hst
data_format = %24.16e
dcycle = 1
user_hist_only = false

<output2>
file_type = bin
variable = turb_force
id = force
dcycle = 3

<output3>
file_type = rst
id = restart
dcycle = 1
