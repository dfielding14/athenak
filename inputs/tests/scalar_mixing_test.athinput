# Scalar mixing test: Mean gradient forcing in frozen turbulent velocity
# 64^3 domain, scalar_only mode, G=1.0

<comment>
problem   = scalar mixing with mean gradient forcing
reference = autonomous scalar implementation

<job>
problem_id = scalar_mixing
basename   = scalar_mix

<time>
evolution  = dynamic
cfl_number = 0.4
tlim       = 2.0
nlim       = -1

<mesh>
nghost = 2
nx1    = 64
x1min  = 0.0
x1max  = 1.0
ix1_bc = periodic
ox1_bc = periodic

nx2    = 64
x2min  = 0.0
x2max  = 1.0
ix2_bc = periodic
ox2_bc = periodic

nx3    = 64
x3min  = 0.0
x3max  = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 64
nx2 = 64
nx3 = 64

<hydro>
eos             = ideal
gamma           = 1.6666666666667
reconstruct     = plm
rsolver         = hllc
nscalars        = 1
scalar_only     = true

<problem>
rho0           = 1.0
temp0          = 1.0
scalar_init    = 10.0
user_srcs      = true
mean_gradient  = 1.0
turb_v_rms     = 1.0
turb_nlow      = 1
turb_nhigh     = 16
turb_expo      = 1.6666667
turb_sol_frac  = 1.0
turb_rseed     = 12345

<output1>
file_type  = bin
variable   = hydro_w
dt         = 0.5
