# AthenaXXX input file for passive-MHD PIC isolation tests

<comment>
problem   = PIC passive-MHD isolation mode

<job>
basename  = pic_mhd_passive

<mesh>
nghost    = 2          # Number of ghost cells
nx1       = 16         # Number of zones in X1-direction
x1min     = 0.0        # minimum value of X1
x1max     = 16.0       # maximum value of X1
ix1_bc    = periodic   # inner-X1 boundary flag
ox1_bc    = periodic   # outer-X1 boundary flag

nx2       = 8          # Number of zones in X2-direction
x2min     = 0.0        # minimum value of X2
x2max     = 8.0        # maximum value of X2
ix2_bc    = periodic   # inner-X2 boundary flag
ox2_bc    = periodic   # outer-X2 boundary flag

nx3       = 8          # Number of zones in X3-direction
x3min     = 0.0        # minimum value of X3
x3max     = 8.0        # maximum value of X3
ix3_bc    = periodic   # inner-X3 boundary flag
ox3_bc    = periodic   # outer-X3 boundary flag

<meshblock>
nx1       = 4          # Number of cells in each MeshBlock, X1-dir
nx2       = 4          # Number of cells in each MeshBlock, X2-dir
nx3       = 4          # Number of cells in each MeshBlock, X3-dir

<time>
evolution  = dynamic   # dynamic/kinematic/static
integrator = rk2       # time integration algorithm
cfl_number = 0.3       # Courant number
nlim       = 2         # cycle limit
tlim       = 1.0       # time limit
ndiag      = 1         # cycles between diagnostic output

<mhd>
eos         = ideal
reconstruct = plm
rsolver     = llf
gamma       = 1.66666666667

<particles>
particle_type           = cosmic_ray
ppc                     = 1.0
pusher                  = drift
nspecies                = 1
cr_distribution         = center
deposit_moments         = true
deposit_order           = 1
deposit_qscale          = 1.0
couple_moments_to_mhd   = false
couple_j_to_efield_coeff = 1.0
couple_j_to_efield_representation = cell_centered
couple_j_deposition_mode = cc_convert
couple_moments_momentum_to_mhd = false
couple_moments_energy_to_mhd   = false
couple_fluid_feedback_order    = mhd_src_terms
couple_moments_momentum_coeff  = 1.0
couple_moments_energy_coeff    = 1.0
cr_vx0                  = 0.50
cr_vy0                  = -0.25
cr_vz0                  = 0.125
pic_background_mode     = passive_mhd
pic_interp_scheme       = tsc
pic_cr_light_speed      = 1.0
pic_max_cell_cross      = 2
pic_theta_max           = 0.3
pic_deltaf_mode         = off
pic_deltaf_f0           =
pic_sort_interval       = 0
pic_intermediate_arrays = auto
pic_expanding_box_mode  = off
pic_expansion_rate_x1   = 0.0
pic_expansion_rate_x2   = 0.0
pic_expansion_rate_x3   = 0.0

<species0>
mass   = 1.0
charge = 1.0

<problem>
pgen_name = linear_wave
wave_flag = 0
amp       = 1.0e-6
vflow     = 0.0
along_x1  = true
along_x2  = false
along_x3  = false

<output1>
file_type   = bin
variable    = prtcl_rho
id          = prtcl_rho
dcycle      = 1
ghost_zones = false

<output2>
file_type   = bin
variable    = prtcl_jx
id          = prtcl_jx
dcycle      = 1
ghost_zones = false

<output3>
file_type   = bin
variable    = prtcl_jy
id          = prtcl_jy
dcycle      = 1
ghost_zones = false

<output4>
file_type   = bin
variable    = prtcl_jz
id          = prtcl_jz
dcycle      = 1
ghost_zones = false

<output5>
file_type   = bin
variable    = mhd_bcc
id          = mhd_bcc
dcycle      = 1
ghost_zones = false

<output6>
file_type   = bin
variable    = prtcl_d
id          = prtcl_d
dcycle      = 1
ghost_zones = false

<output7>
file_type   = bin
variable    = mhd_u_m1
id          = mhd_u_m1
dcycle      = 1
ghost_zones = false

<output8>
file_type   = bin
variable    = mhd_u_m2
id          = mhd_u_m2
dcycle      = 1
ghost_zones = false

<output9>
file_type   = bin
variable    = mhd_u_m3
id          = mhd_u_m3
dcycle      = 1
ghost_zones = false

<output10>
file_type   = bin
variable    = mhd_u_e
id          = mhd_u_e
dcycle      = 1
ghost_zones = false
