# Controlled state between the oblique and parallel firehose thresholds.

<job>
basename = cgl_lf_firehose_policy

<mesh>
nghost = 2
nx1 = 16
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 16
nx2 = 1
nx3 = 1

<time>
evolution = kinematic
integrator = rk2
sts_integrator = rkl2
sts_max_dt_ratio = 1000.0
cfl_number = 0.4
nlim = 1
tlim = 0.005
ndiag = 1

<mhd>
eos = cgl
passive = false
firehose_limiter = true
cgl_firehose_threshold = oblique
backup_limiters = false
limiter_nu_coll = 0.0
cgl_heat_flux = landau_fluid
cgl_heat_flux_integrator = sts
cgl_lf_strict_admissibility = true
lf_k_parallel = 6.283185307179586
lf_coefficient_mode = background
lf_c_parallel0 = 1.0
reconstruct = plm
rsolver = advect
gamma = 1.666666666666667
dfloor = 1.0e-12
pfloor = 1.0e-12
tfloor = 1.0e-12
sfloor = 1.0e-12
bfloor = 1.0e-10

<problem>
pgen_name = cgl_landau_fluid
test_mode = limiter_stress
limiter_kind = firehose
rho0 = 1.0
ppar0 = 1.85
pperp0 = 1.0
b0 = 1.0
amp = 0.0
backup_bound_tol = 1.02

<output1>
file_type = hst
data_format = %24.16e
dcycle = 1
