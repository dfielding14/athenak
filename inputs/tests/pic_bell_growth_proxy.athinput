# AthenaXXX input file for PIC Bell growth proxy test

<comment>
problem   = Current-driven Bell-like growth proxy in coupled MHD-PIC mode

<job>
basename  = pic_bell_growth_proxy

<mesh>
nghost    = 2
nx1       = 16
x1min     = 0.0
x1max     = 16.0
ix1_bc    = periodic
ox1_bc    = periodic

nx2       = 8
x2min     = 0.0
x2max     = 8.0
ix2_bc    = periodic
ox2_bc    = periodic

nx3       = 8
x3min     = 0.0
x3max     = 8.0
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 4
nx2       = 4
nx3       = 4

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.3
nlim       = 20
tlim       = 2.0
ndiag      = 1

<mhd>
eos         = ideal
reconstruct = plm
rsolver     = llf
gamma       = 1.66666666667

<particles>
particle_type           = cosmic_ray
ppc                     = 1.0
pusher                  = drift
nspecies                = 1
cr_distribution         = center
deposit_moments         = true
deposit_order           = 1
deposit_qscale          = 1.0
couple_moments_to_mhd   = false
couple_moments_momentum_to_mhd = false
couple_moments_energy_to_mhd   = false
cr_vx0                  = 0.8
cr_vy0                  = 0.0
cr_vz0                  = 0.0
pic_background_mode     = coupled
pic_feedback_mode       = coupled

<species0>
mass   = 1.0
charge = 1.0

<problem>
pgen_name = linear_wave
wave_flag = 0
amp       = 1.0e-6
vflow     = 0.0
along_x1  = true
along_x2  = false
along_x3  = false

<output1>
file_type   = bin
variable    = mhd_bcc
id          = mhd_bcc
dcycle      = 1
ghost_zones = false
