# Scalar-mixing Clebsch audit: init-only 3D run with diagnostics enabled

<comment>
problem   = scalar mixing Clebsch audit in 3D
reference = multi-seed audit for notebook-style 3D Clebsch initialization

<job>
problem_id = scalar_mixing
basename   = scalar_mix_clebsch_3d_audit

<time>
evolution  = dynamic
cfl_number = 0.4
tlim       = 0.0
nlim       = -1

<mesh>
nghost = 2
nx1    = 32
x1min  = 0.0
x1max  = 1.0
ix1_bc = periodic
ox1_bc = periodic

nx2    = 32
x2min  = 0.0
x2max  = 1.0
ix2_bc = periodic
ox2_bc = periodic

nx3    = 32
x3min  = 0.0
x3max  = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 32
nx2 = 32
nx3 = 32

<hydro>
eos             = ideal
gamma           = 1.6666666666667
reconstruct     = plm
rsolver         = hllc
nscalars        = 1
scalar_only     = true

<problem>
rho0                          = 1.0
temp0                         = 1.0
user_srcs                     = false
mean_gradient                 = 0.0
turb_velocity_method          = clebsch
turb_alpha                    = 0.3333333333333333
turb_v_rms                    = 1.0
turb_nlow                     = 2
turb_nhigh                    = 6
turb_expo                     = 1.6666667
turb_rseed                    = 12345
turb_k_crit                   = 16.0
turb_dump_generator_diagnostics = true
