# LEGACY NAME: engineering proxy only; not Sun & Bai (2023) reproduction evidence.
# AthenaXXX input file for publication-local AMR shock-rich O-T + coupled PIC

<comment>
problem   = publication local profile (laptop-stable staging, np8 validation)

<job>
basename  = pic_amr_shock_pub_local

<mesh>
nghost    = 2
nx1       = 32
x1min     = -0.5
x1max     = 0.5
ix1_bc    = periodic
ox1_bc    = periodic

nx2       = 32
x2min     = -0.5
x2max     = 0.5
ix2_bc    = periodic
ox2_bc    = periodic

nx3       = 8
x3min     = -0.5
x3max     = 0.5
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 8
nx2       = 8
nx3       = 4

<mesh_refinement>
refinement           = adaptive
num_levels           = 2
ddens_max            = 0.12
# keep refinement controls configured, but defer AMR churn for laptop-stable runs
ncycle_check         = 1000
refinement_interval  = 1000
max_nmb_per_rank     = 4096

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.3
nlim       = 320
tlim       = 1.2
ndiag      = 1

<mhd>
eos         = ideal
reconstruct = plm
rsolver     = llf
gamma       = 1.666666667

<particles>
particle_type                 = cosmic_ray
ppc                           = 2.0
pusher                        = boris_tsc
nspecies                      = 1
cr_distribution               = random
deposit_moments               = true
deposit_order                 = 1
deposit_qscale                = 1.0
couple_moments_to_mhd         = false
couple_j_to_efield_representation = cell_centered
couple_moments_momentum_to_mhd = false
couple_moments_energy_to_mhd  = false
cr_vx0                        = 0.4
cr_vy0                        = 0.0
cr_vz0                        = 0.0
pic_background_mode           = coupled
pic_feedback_mode             = test_particle
pic_sort_interval             = 8
pic_intermediate_arrays       = auto

<species0>
mass   = 1.0
charge = 1.0

<problem>
pgen_name    = orszag_tang
ot_mach      = 1.00

<output1>
file_type   = bin
variable    = mhd_w_d
id          = rho
dcycle      = 8
ghost_zones = false

<output2>
file_type   = bin
variable    = mhd_bmag
id          = bmag
dcycle      = 8
ghost_zones = false

<output3>
file_type   = bin
variable    = mhd_j2
id          = j2
dcycle      = 8
ghost_zones = false

<output4>
file_type   = bin
variable    = prtcl_rho
id          = prtcl_rho
dcycle      = 8
ghost_zones = false

<output5>
file_type   = bin
variable    = prtcl_jx
id          = prtcl_jx
dcycle      = 8
ghost_zones = false

<output6>
file_type   = bin
variable    = prtcl_jy
id          = prtcl_jy
dcycle      = 8
ghost_zones = false

<output7>
file_type   = bin
variable    = prtcl_jz
id          = prtcl_jz
dcycle      = 8
ghost_zones = false

<output8>
file_type   = bin
variable    = prtcl_dedt
id          = prtcl_dedt
dcycle      = 8
ghost_zones = false

<output9>
file_type   = bin
variable    = prtcl_dpxdt
id          = prtcl_dpxdt
dcycle      = 8
ghost_zones = false

<output10>
file_type   = bin
variable    = prtcl_dpydt
id          = prtcl_dpydt
dcycle      = 8
ghost_zones = false

<output11>
file_type   = bin
variable    = prtcl_dpzdt
id          = prtcl_dpzdt
dcycle      = 8
ghost_zones = false

<output12>
file_type   = bin
variable    = prtcl_ebdot
id          = prtcl_ebdot
dcycle      = 8
ghost_zones = false

<output13>
file_type   = pvtk
variable    = prtcl_all
id          = prtcl_all
dcycle      = 16

<output14>
file_type   = rst
dcycle      = 160
