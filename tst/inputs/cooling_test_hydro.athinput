# AthenaK input file for isolated 1D cooling source-term regression tests.

<comment>
problem = uniform hydro cooling source-term test

<job>
basename = cooling_test

<mesh>
nghost = 2
nx1 = 8
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic

nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic

nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 8
nx2 = 1
nx3 = 1

<time>
evolution = dynamic
integrator = rk2
cfl_number = 0.4
nlim = 1
tlim = 1.0e-3
ndiag = 100

<units>
length_cgs = 1.0
mass_cgs = 1.0
time_cgs = 1.0

<hydro>
eos = ideal
reconstruct = plm
rsolver = llf
gamma = 1.6666666666666667
nscalars = 1

<problem>
pgen_name = cooling_test
density = 1.0
pressure = 1.0
vx = 0.0
vy = 0.0
vz = 0.0
scalar0 = 0.0
register_user_cooling = false
user_lambda = 0.0
user_gamma = 0.0
user_lambda_units = code
user_gamma_units = code

<cooling>
enabled = true
units = code
cooling_model = powerlaw
heating_model = none
cooling_density = mass_density
heating_density = mass_density
cooling_bounds = zero
heating_bounds = zero
cooling_table = inputs/tables/cooling_lambda_1d.tbl
cgm_pie_table = inputs/tables/cooling_cgm_pie.tbl
cgm_cie_table = inputs/tables/cooling_cgm_cie.tbl
cooling_powerlaw_axis = temperature
cooling_powerlaw_axis_units = code
cooling_powerlaw_density_kind = mass_density
cooling_powerlaw_value_units = code
cooling_reference_axis = 1.0
cooling_reference_value = 1.0e-2
cooling_slope = 0.0
cooling_breaks = 0.5,1.5
cooling_slopes = 0.0,0.0,0.0
heating_rate = 0.0
heating_table = inputs/tables/cooling_gamma_1d.tbl
cooling_modifier_model = none
cooling_modifier = 1.0
cooling_modifier_table = inputs/tables/cooling_modifier_1d.tbl
heating_modifier_model = none
heating_modifier = 1.0
heating_modifier_table = inputs/tables/cooling_modifier_1d.tbl
shielding_model = none
timestep = false
timestep_factor = 1.0
timestep_use_temperature_bounds = false
timestep_temperature_units = code
timestep_temperature_min = 0.0
timestep_temperature_max = 1.0
timestep_use_density_bounds = false
timestep_density_units = code
timestep_density_kind = mass_density
timestep_density_min = 0.0
timestep_density_max = 1.0
history = true
history_gross = true
history_net = true

<output1>
file_type = hst
data_format = %24.16e
dcycle = 1
