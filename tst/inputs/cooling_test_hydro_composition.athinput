# AthenaK input file for cooling tests that require cgs composition metadata.

<comment>
problem = uniform hydro cooling source-term test with composition

<job>
basename = cooling_test_composition

<mesh>
nghost = 2
nx1 = 8
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic

nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic

nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 8
nx2 = 1
nx3 = 1

<time>
evolution = dynamic
integrator = rk2
cfl_number = 0.4
nlim = 1
tlim = 1.0e-3
ndiag = 100

<units>
length_cgs = 1.0
mass_cgs = 1.0
time_cgs = 1.0

<hydro>
eos = ideal
reconstruct = plm
rsolver = llf
gamma = 1.6666666666666667
nscalars = 1

<problem>
pgen_name = cooling_test
density = 1.0
pressure = 1.0
vx = 0.0
vy = 0.0
vz = 0.0
scalar0 = 0.0
register_user_cooling = false

<cooling>
enabled = true
units = code
cooling_model = cgm
heating_model = none
cooling_density = mass_density
heating_density = mass_density
cooling_bounds = zero
heating_bounds = zero
cgm_pie_table = inputs/tables/cooling_cgm_pie.tbl
cgm_cie_table = inputs/tables/cooling_cgm_cie.tbl
shielding_model = cgm_approx
mu = 1.0
hydrogen_mass_fraction = 1.0
timestep = false
timestep_factor = 1.0
history = true
history_gross = true
history_net = true

<output1>
file_type = hst
data_format = %24.16e
dcycle = 1
