# Serial AMR refine/derefine bookkeeping test for lagrangian_mc tracks.

<job>
basename  = particle_amr_refine_derefine

<mesh>
nghost    = 2
nx1       = 4
x1min     = 0.0
x1max     = 1.0
ix1_bc    = periodic
ox1_bc    = periodic

nx2       = 4
x2min     = 0.0
x2max     = 1.0
ix2_bc    = periodic
ox2_bc    = periodic

nx3       = 1
x3min     = 0.0
x3max     = 1.0
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 4
nx2       = 4
nx3       = 1

<mesh_refinement>
refinement          = adaptive
num_levels          = 2
ncycle_check        = 1
refinement_interval = 1
max_nmb_per_rank    = 16

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.4
nlim       = 8
tlim       = 1.0
ndiag      = 1

<hydro>
eos         = ideal
reconstruct = dc
rsolver     = llf
gamma       = 1.6666666666666667
nscalars    = 1

<particles>
particle_type = lagrangian_mc
pusher        = lagrangian_mc
ppc           = 0.0
assign_tag    = index_order
random_seed   = 12345

<problem>
user_srcs         = true
user_work_in_loop = true
test_mode         = amr_refine_derefine
field_profile     = uniform
particle_layout   = cell_centers
rho0              = 1.0
temp0             = 2.0
scalar0           = 0.25
vx0               = 0.0
vy0               = 0.0
vz0               = 0.0
t_refine          = 0.0
t_derefine        = 0.12

<output1>
file_type   = trk
id          = trk
variable    = prtcl_all
dt          = 10.0
nparticles  = 16
